{
  "expo": {
    "name": "Panini App",
    "slug": "panini-app",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/netto-panino-icon.png",
    "scheme": "panini-app",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.leuro.paniniapp",
      "versionCode": 4,
      "adaptiveIcon": {
        "backgroundColor": "#fefee5",
        "foregroundImage": "./assets/images/netto-panino-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/netto-panino-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/netto-panino-icon.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#fefee5",
          "dark": {
            "backgroundColor": "#373928"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}